# Terraform state files
*.tfstate
*.tfstate.backup

# Terraform lock file (optional: keep if you want version consistency)
.terraform.lock.hcl

# Terraform directory (cache/plugins)
.terraform/

# Sensitive variable files
*.tfvars.json

# Crash logs
crash.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json